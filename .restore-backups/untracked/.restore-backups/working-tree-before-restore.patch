-  if (lower.includes('analisis') || lower.includes('análisis') || lower.includes('review')) candidates.push('Analisis')
-  if (lower.includes('rumor') || lower.includes('filtr')) candidates.push('Rumores')
-  candidates.push('Nintendo Switch')
-
-  const known = availableCategories.filter(Boolean)
-  const normalized = candidates.map(category => {
-    return known.find(option => option.toLowerCase() === category.toLowerCase()) || category
-  })
-
-  return [...new Set(normalized)].slice(0, 3)
-}
