-export async function handler(event) {
-  if (event.httpMethod !== 'POST') {
-    return {
-      statusCode: 405,
-      body: JSON.stringify({ error: 'Metodo no permitido' })
-    }
-  }
-
-  try {
-    const { tema, categorias = [], opciones = {} } = JSON.parse(event.body || '{}')
-    const cleanTopic = String(tema || '').trim()
-
-    if (!cleanTopic) {
-      return {
-        statusCode: 400,
-        body: JSON.stringify({ error: 'Escribe un tema para crear el post' })
-      }
-    }
-
-    let titles = []
-    let imageUrl = null
-
-    // Search for image if requested
-    if (opciones.searchImage) {
-      imageUrl = await searchImage(cleanTopic)
-    }
-
-    try {
-      const rssUrl = `https://news.google.com/rss/search?q=${encodeURIComponent(cleanTopic)}&hl=es-419&gl=US&ceid=US:es-419`
-      const response = await fetch(rssUrl, {
-        headers: {
-          'User-Agent': 'WidgetDreamsPostGenerator/1.0'
-        }
-      })
-
-      if (response.ok) {
-        const xml = await response.text()
-        const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/gi)]
-          .slice(0, 8)
-          .map(match => match[1])
-
-        titles = items
-          .map(item => extractTag(item, 'title'))
-          .map(title => title.replace(/\s+-\s+[^-]+$/, '').trim())
-          .filter(Boolean)
-      }
-    } catch (rssError) {
-      console.warn('RSS no disponible, usando borrador base', rssError)
-    }
-
-    const firstTitle = titles[0] || `Análisis completo sobre ${cleanTopic}`
-    const summary = opciones.longDescriptions 
-      ? `En este análisis exhaustivo exploramos todas las novedades y desarrollos importantes sobre ${cleanTopic}. Cubrimos los aspectos más relevantes, desde los anuncios recientes hasta las perspectivas futuras, ofreciendo una visión completa que te mantendrá completamente informado sobre este tema tan significativo en el mundo de los videojuegos.`
-      : `Estas son las novedades mas recientes sobre ${cleanTopic}.`
-    
-    const sections = generateContent(cleanTopic, titles, opciones)
-    const stickers = ['🔥', '⭐', '🎮', '🚀', '💫']
-    const randomSticker = stickers[Math.floor(Math.random() * stickers.length)]
-
-    return {
-      statusCode: 200,
-      body: JSON.stringify({
-        titulo: firstTitle,
-        categorias: pickCategories(cleanTopic, categorias),
-        sticker: randomSticker,
-        resumen: summary,
-        imagen: imageUrl,
-        secciones: sections
-      })
-    }
-  } catch (error) {
-    console.error(error)
-    return {
-      statusCode: 500,
-      body: JSON.stringify({ error: 'No se pudo generar el post automaticamente' })
-    }
-  }
-}
